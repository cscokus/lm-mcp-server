# ── Incoming auth ─────────────────────────────────────────────────────────────
# The bearer token Claude Cowork presents when connecting to this MCP server.
# Generate a long random value (e.g. `openssl rand -hex 32`) and register it as
# the connector's auth token on the Claude side.
MCP_AUTH_TOKEN=change-me-to-a-long-random-secret

# ── CRM API (Liquid-Mind-CRM Express app) ─────────────────────────────────────
# Where the READ tools and the PROPOSE (Action_Queue) tools send their calls.
# Use a localhost / private URL when co-located; a private VPC IP once split out.
CRM_BASE_URL=http://localhost:3000
# A service credential the CRM accepts on the Authorization: Bearer header.
# See README "CRM-side contract" — the CRM must accept a non-interactive service token.
CRM_SERVICE_TOKEN=

# ── WebPages PHP tools (LiquidMindWebPages) ───────────────────────────────────
# Reserved for the EXECUTE phase (Quick Campaign Tool, Audience Tool, ...).
# Not used by any v1 tool. Leave blank for now.
WEBTOOLS_BASE_URL=http://localhost
WEBTOOLS_SERVICE_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8930
